{
  "pluginAlias": "ModernFormsFans",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "Modern Forms Fans"
      },
      "autoDiscover": {
        "title": "Auto discover",
        "description": "Disable automatic discovery of fans on your local network.",
        "type": "boolean",
        "default": true
      },
      "pollingInterval": {
        "title": "Polling Interval",
        "description": "Defines how often (in seconds) fans are queried for state on the network.",
        "type": "number",
        "default": 5
      },
      "mqttUrl": {
        "title": "MQTT Server URL",
        "description": "Configure MQTT server for switch notifications",
        "type": "string"
      },
      "fans": {
        "title": "Fans",
        "description": "(optional) Fans will be automatically discovered.",
        "type": "array",
        "items": {
          "title": "Fan",
          "type": "object",
          "properties": {
            "ip": {
              "title": "IP",
              "type": "string",
              "format": "ipv4"
            },
            "light": {
              "title": "Light",
              "type": "boolean",
              "default": true
            },
            "switch": {
              "title": "Switch Topic",
              "type": "string"
            }
          },
          "required": ["ip"]
        }
      }
    }
  }
}
